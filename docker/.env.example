# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llm_gateway

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# vLLM (for local models)
VLLM_ENDPOINT=http://localhost:8000

# Security
SECRET_KEY=change-me-to-a-random-string-in-production

# OAuth (Optional)
APP_URL=http://localhost:8000

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram/your-token
TELEGRAM_ALLOWED_CHATS=123456789,987654321

# Cohere Rerank (Optional)
COHERE_API_KEY=your-cohere-api-key
