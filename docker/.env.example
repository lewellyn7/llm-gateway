# =============================================================================
# LLM Gateway - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_PORT=28000
SECRET_KEY=change-me-to-a-random-string-in-production-at-least-32-chars

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llm_gateway
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Kafka (Optional)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key

# -----------------------------------------------------------------------------
# Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# -----------------------------------------------------------------------------
# vLLM (Local Models)
# -----------------------------------------------------------------------------
VLLM_ENDPOINT=http://localhost:8000

# -----------------------------------------------------------------------------
# Moonshot
# -----------------------------------------------------------------------------
MOONSHOT_API_KEY=your-moonshot-api-key

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_VERSION=2024-02-01

# -----------------------------------------------------------------------------
# Cohere (Rerank)
# -----------------------------------------------------------------------------
COHERE_API_KEY=your-cohere-api-key

# -----------------------------------------------------------------------------
# OAuth
# -----------------------------------------------------------------------------
APP_URL=http://localhost:28000
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram/your-token
TELEGRAM_ALLOWED_CHATS=123456789,987654321

# -----------------------------------------------------------------------------
# Discord Bot
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token

# -----------------------------------------------------------------------------
# Slack Bot
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=your-slack-bot-token
